# =============================================================================
# IFNOTUS — Environment Configuration
# Copy to .env and adjust values for your environment
# =============================================================================

# Application
APP_NAME=IFNOTUS
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
API_V1_PREFIX=/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# Security — CHANGE IN PRODUCTION
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://ifnotus:ifnotus@localhost:5432/ifnotus

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TASK_QUEUE=ifnotus:tasks

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Plugins
PLUGINS_ENABLED=true
PLUGINS_DIR=plugins

# Integrations (optional)
NETDATA_URL=
NGINX_CONFIG_PATH=/etc/nginx
GITHUB_API_URL=https://api.github.com

# SMTP (optional — for operations panel test)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Operations
OPERATIONS_BACKUP_DIR=.ifnotus/backups
WORKER_SERVICE_NAME=
APPLICATIONS_DIR=applications
APPLICATIONS_RELOAD_INTERVAL_SECONDS=60

# Monitoring engine
MONITORING_CACHE_TTL_SECONDS=15
MONITORING_HISTORY_POINTS=60
MONITORING_LOG_PATHS=/var/log/syslog,/var/log/system.log
MONITORING_CPU_ALERT_THRESHOLD=85
MONITORING_MEMORY_ALERT_THRESHOLD=85
MONITORING_DISK_ALERT_THRESHOLD=90
MONITORING_EXPECTED_PORTS=8000,5173,5432,6379
MYSQL_URL=
SUPERVISOR_SOCKET=/var/run/supervisor.sock

# Hosting control panel
WEBMAIL_URL=
CERTBOT_BINARY=certbot
SERVER_PUBLIC_IP=
HOSTING_ALLOWED_PATHS=/var/www,/home
MAIL_CONFIG_DIR=.ifnotus/mail
TERMINAL_COMMAND_TIMEOUT=30
TERMINAL_MAX_OUTPUT_BYTES=65536
